# Copy to .env (repo root) and adjust. Loaded by docker-compose and by the
# backend, which looks for .env in its working directory and in the parent —
# so `make run-backend` picks this file up. Real env vars always win.

# ── Postgres + Apache AGE (graph core) ───────────────────────────────
POSTGRES_USER=perspective
POSTGRES_PASSWORD=perspective
POSTGRES_DB=perspectivegraph
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# AGE graph name created on startup
AGE_GRAPH_NAME=perspective

# ── NATS JetStream (event bus) ───────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_STREAM=PERSPECTIVE
NATS_SUBJECT=perspective.events.*

# ── HTTP servers ─────────────────────────────────────────────────────
# GraphQL API / BFF
API_ADDR=:8080
# Ingestion webhook receiver
INGEST_ADDR=:8081

# ── Analyzer ─────────────────────────────────────────────────────────
# How often the attack-path analyzer re-scans the graph
ANALYZER_INTERVAL=30s
# Max attack-path length (bounds the path search). Real attack chains are short.
ANALYZER_MAX_HOPS=12
# Compute critical paths in the database (Apache AGE Cypher) instead of the
# default in-process Dijkstra. OFF by default: AGE has no weighted shortest-path,
# so this enumerates paths (variable-length match) — unbounded in the worst case
# on dense/cyclic graphs. It's safe-railed (statement_timeout + LIMIT, with a
# fallback to Dijkstra on timeout) but reserved for graphs known to be bounded.
# Dijkstra is polynomial and the right default for the per-pass "all paths" scan.
ANALYZER_DB_PATHS=false

# ── GitHub PR commenter (action layer) ───────────────────────────────
# Token with `pull_requests: write`. Leave empty to run in dry-run (comments
# are logged, not posted) — the default for local dev.
GITHUB_TOKEN=
# Override for GitHub Enterprise, e.g. https://ghe.example.com/api/v3
GITHUB_API_URL=https://api.github.com
# Force dry-run even when a token is set (logs the comment instead of posting)
GITHUB_DRY_RUN=false

# ── GitLab MR commenter (action layer) ───────────────────────────────
# Personal/project access token with `api` scope. Empty → dry-run.
GITLAB_TOKEN=
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_DRY_RUN=false

# ── OpenSearch full-text index (optional) ────────────────────────────
# Leave empty to disable. To enable with the full-stack compose, start both
# profiles (`docker compose --profile app --profile search up -d --build`) and
# set this to the in-network service URL so the backend container can reach it:
#   OPENSEARCH_URL=http://opensearch:9200
# For the host dev loop (make run-backend) use http://localhost:9200 instead.
OPENSEARCH_URL=

# ── Threat intel: CISA KEV + FIRST EPSS (optional) ───────────────────
# When on, CVE nodes are enriched with "exploited in the wild" (KEV) and the
# 30-day exploitation probability (EPSS), reweighting AFFECTS edges. Fetches
# live from the official feeds (cached); off → severity-derived weights stand.
THREATINTEL=off
# Optional overrides (air-gapped mirrors / testing); blank uses the official feeds.
KEV_FEED_URL=
EPSS_API_URL=

# ── Auth & multi-tenancy (optional; OPEN with a loud warning when unset) ──
# Ingest webhooks: HMAC-SHA256 of the request body (header
# X-PerspectiveGraph-Signature: sha256=<hex>). The secret never travels.
# INGEST_HMAC_SECRET is the default tenant's secret; INGEST_HMAC_SECRETS gives
# each tenant its own (the X-Tenant header selects it → real data isolation).
INGEST_HMAC_SECRET=
INGEST_HMAC_SECRETS=          # tenant-a:secretA,tenant-b:secretB
# GraphQL API bearer tokens. Each entry: token:role[:tenant[:expiry[:app1|app2]]]
#   - token : the bearer value, OR "sha256$<hex>" to store only its hash (so the
#             live secret never sits at rest in env/config). Hash: printf %s TOKEN | sha256sum
#   - role  : viewer | operator | admin
#   - tenant: optional (defaults to "default"; leave the field empty to keep it)
#   - expiry: optional YYYY-MM-DD; the token is rejected after that UTC day (rotation)
#   - apps  : optional pipe-separated app allowlist → the principal can only READ
#             attack paths / assets touching those apps (object-level RBAC).
# When set, GraphiQL is disabled and the dashboard must be built with VITE_API_TOKEN.
#   API_TOKENS=tok-a:viewer,tok-b:admin:globex,sha256$<hex>:viewer:default:2026-12-31:payments|web
API_TOKENS=
# OIDC/JWT (alongside or instead of static tokens): RS256 JWTs are verified
# against the JWKS; role/tenant/apps come from the "role"/"tenant"/"apps" claims
# (apps = JSON array or delimited string → same per-application read scoping).
# Fail-closed:
# if OIDC_JWKS_URL is set, OIDC_ISSUER and OIDC_AUDIENCE are REQUIRED (the backend
# refuses to start otherwise), so a verifier can't silently skip iss/aud checks.
OIDC_JWKS_URL=
OIDC_ISSUER=
OIDC_AUDIENCE=
# Browser origins allowed to call the API cross-origin (comma-separated). Default
# is the Vite dev server + the docker-compose dashboard. Set to your dashboard's
# real origin in production; "*" allows any origin (not recommended); an empty
# value disables CORS entirely (same-origin only).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Data protection & abuse detection ───────────────────────────────
# STORE_ENCRYPTION_KEY encrypts the file-backed governance stores (suppressions,
# tickets, validations, history) AND the audit log at rest with AES-256-GCM, so a
# stolen volume/backup doesn't surrender the attack map + who-viewed-it in
# plaintext. A 64-hex-char value is the raw key; anything else is a passphrase.
# Empty → plaintext on disk. Generate one with: openssl rand -hex 32
STORE_ENCRYPTION_KEY=
# EXPORT_SIGNING_KEY (Ed25519, 64-hex seed) signs the OSCAL/SIEM exports with a
# detached signature so an auditor/SIEM can verify integrity + origin; fetch the
# public key at GET /export/pubkey. Empty → exports are unsigned.
# Generate one with: openssl rand -hex 32
EXPORT_SIGNING_KEY=
# AUTH_LOCKOUT_THRESHOLD: failed API auth attempts from one IP within 5 minutes
# before that IP is locked (HTTP 429) for 15 minutes and an alert is logged +
# audited. 0 disables. EXFIL_ALERT_THRESHOLD: attack-path views/exports by one
# principal within 5 minutes before an exfiltration alert fires. 0 disables.
AUTH_LOCKOUT_THRESHOLD=50
EXFIL_ALERT_THRESHOLD=0

# ── Audit (optional; tamper-evident hash-chained log) ────────────────
# Append-only JSONL; each record links to the previous via SHA-256, so any
# edit is detectable. Records writes AND READS of the attack map — views of the
# attack paths/graph (with the path ids seen) and exports (OSCAL/NDJSON) — so you
# can answer "who saw, or exfiltrated, which attack paths". The tool is a map of
# how to breach the org, so its reads are governed too.
# Verify the chain with: perspectivegraph verify-audit <path>
AUDIT_LOG_PATH=              # e.g. /var/log/perspectivegraph/audit.log

# ── Temporal history (optional; file-backed) ─────────────────────────
# Per-path lifecycle (first/last seen, open/resolved → MTTR, reopen count) and a
# posture trend series, recorded each analyzer pass. Powers "open for N days",
# MTTR, regression detection and the dashboard trend sparkline. Empty → in-memory
# only (resets on restart, so path age and trends start over). Point it at a path
# on a writable volume to persist across restarts.
HISTORY_PATH=               # e.g. /var/lib/perspectivegraph/history.json

# ── Remediation ticketing (optional) ─────────────────────────────────
# Turn an attack path into an owned, tracked ticket (closed-loop action). The
# local board (one open ticket per path, with owner + status) persists to
# TICKETS_PATH; empty → in-memory only. Set TICKET_WEBHOOK_URL to also POST each
# new ticket to an external tracker (Jira/GitHub/SOAR); empty → dry-run (the
# ticket is logged and tracked locally only).
TICKETS_PATH=               # e.g. /var/lib/perspectivegraph/tickets.json
TICKET_WEBHOOK_URL=         # e.g. https://hooks.example.com/tickets

# ── Red-team / BAS validation (optional; file-backed) ────────────────
# Verdicts on whether attack paths are real (confirmed / refuted / partial) plus
# the false-negatives a tester found (missed) — the evidence behind the precision
# & recall the dashboard reports. A BAS platform (Caldera/AttackIQ/SafeBreach) or
# a human POSTs to /validations. Empty → in-memory only (lost on restart).
VALIDATIONS_PATH=           # e.g. /var/lib/perspectivegraph/validations.json

# ── Triage / suppression board (optional; file-backed) ───────────────
# Analyst decisions to take a specific attack path off the active board —
# accept-risk / false-positive / mitigating-control / duplicate, each with an
# accountable owner and optional expiry — persist here as JSON. Expired
# suppressions automatically return the path to the active board. Empty → the
# board works but lives in memory only and is lost on restart.
SUPPRESSIONS_PATH=          # e.g. /var/lib/perspectivegraph/suppressions.json

# ── Drift alerting (optional; chat/SOAR webhook) ─────────────────────
# When a NEW attack path appears between analysis passes, POST an alert.
# format "slack" → {"text": …} (Slack/Mattermost); "generic" → raw drift JSON.
ALERT_WEBHOOK_URL=           # e.g. https://hooks.slack.com/services/...
ALERT_WEBHOOK_FORMAT=slack   # slack | generic

# ── Rate limiting (per client IP; 0 disables) ────────────────────────
# Token-bucket cap on the ingest webhook and the GraphQL API. Generous defaults
# that never throttle `make seed` or the dashboard; lower them at an exposed edge.
INGEST_RATE_RPS=30
API_RATE_RPS=60

# ── Graph core strictness ────────────────────────────────────────────
# When true, the backend refuses to start if Apache AGE is unreachable instead
# of silently falling back to the (non-persistent) in-memory store. Set true for
# any real deployment so a misconfigured DB fails loudly rather than losing data.
GRAPH_STRICT=false

# ── Graph staleness pruning (optional) ───────────────────────────────
# When set, nodes/edges not re-observed within this window are removed, so assets
# that left the source feeds (a deleted pod, a torn-down security group) stop
# producing PHANTOM attack paths. Pruning is leader-only and runs on a derived
# cadence (≈ TTL/6). Elements that predate the stamp (no last_seen) are never
# pruned. Empty/0 disables it. Set it to a few feed-cycles (e.g. 168h = 7d) so a
# briefly-missed scan doesn't evict a still-present asset. OFF by default — the
# demo seeds once and would otherwise prune itself.
GRAPH_TTL=

# ── Secret scrubbing at ingest (data hygiene) ────────────────────────
# Scanner output can incidentally carry a live credential (a hardcoded AWS key in
# a Semgrep snippet, a token on a Falco command line). The graph is a map of how
# to attack the org, so it must never become a STORE of those secrets. When on
# (default), high-precision secret patterns — AWS/GitHub/Slack/Google tokens, PEM
# private keys, JWTs, and `secret=…`/`password=…` assignments — are redacted out
# of ingested property values before they hit the store; the finding is kept, the
# value is replaced with ***redacted:<kind>*** and the node is stamped
# secrets_scrubbed for audit. Identifiers (ids, names, SHAs, digests, refs) are
# never touched. Retention of the scrubbed findings is governed by GRAPH_TTL.
# Set to false only with a deliberate reason.
SCRUB_INGEST=true

# ── Observability ────────────────────────────────────────────────────
# Prometheus metrics are always exposed at GET /metrics on the API server
# (ingest/normalize/analyzer/dead-letter counters + Go runtime). No config.

# ── Log level: debug | info | warn | error ───────────────────────────
LOG_LEVEL=info
