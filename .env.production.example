# PerspectiveGraph - production environment template.
#
# The compose stack reads every knob from `.env`, so hardening it is a matter of
# filling these in. Copy, complete, and lock it down:
#
#   cp .env.production.example .env && chmod 600 .env
#   docker compose --profile app -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# This turns ON every control the demo leaves off. NEVER commit the filled-in .env.
# For Kubernetes, prefer the Helm chart with values-production.yaml.

# ── Authentication (REQUIRED beyond a trusted boundary) ──────────────
# Bearer tokens: "token:role[:tenant]", comma-separated. Generate: openssl rand -hex 24
API_TOKENS=REPLACE_WITH_TOKEN:admin
# ...or OIDC/SSO instead of (or alongside) static tokens; leave the issuer empty to skip.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_CLIENT_ID=
OIDC_AUTHORIZE_URL=
OIDC_TOKEN_URL=
# Per-client-IP rate limit (requests/sec; 0 disables):
API_RATE_RPS=60

# ── Ingest authenticity (REQUIRED) ───────────────────────────────────
# Scanners must HMAC-sign their webhook bodies. Generate: openssl rand -hex 32
INGEST_HMAC_SECRET=REPLACE_WITH_HMAC_SECRET
INGEST_RATE_RPS=50

# ── Transport security ───────────────────────────────────────────────
# In-app HTTPS: put tls.crt + tls.key in ./tls/ (mounted read-only by
# docker-compose.prod.yml) and point these at them. Or terminate TLS at a reverse
# proxy in front and leave both empty.
TLS_CERT_FILE=/etc/pg/tls/tls.crt
TLS_KEY_FILE=/etc/pg/tls/tls.key
# Restrict browser origins allowed to call the API/dashboard:
CORS_ALLOWED_ORIGINS=https://perspectivegraph.example.com

# ── Database (the connection carries the attack map - encrypt it) ────
# The bundled demo Postgres has no TLS. For sslmode=verify-full use an EXTERNAL
# managed Postgres+AGE and set POSTGRES_HOST to it. Set a strong password either way:
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD
# POSTGRES_HOST=db.internal
POSTGRES_SSLMODE=require

# ── At-rest encryption + signed exports ──────────────────────────────
# Generate each: openssl rand -hex 32
STORE_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX
EXPORT_SIGNING_KEY=REPLACE_WITH_32_BYTE_HEX

# ── Tamper-evident audit log (durable) ───────────────────────────────
# Records reads AND writes of the attack map. Verify the chain later with:
#   docker compose exec backend perspectivegraph verify-audit /var/lib/perspectivegraph/audit.log
AUDIT_LOG_PATH=/var/lib/perspectivegraph/audit.log

# ── Data hygiene (on) ────────────────────────────────────────────────
SCRUB_INGEST=true
